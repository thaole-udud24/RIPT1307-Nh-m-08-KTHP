# Server Port
PORT=3000

# Database Configuration
MONGO_URI=mongodb://127.0.0.1:27017/lunaria

# JWT Secrets
JWT_ACCESS_SECRET=lunaria_access_secret_key_random_string_123456789
JWT_REFRESH_SECRET=lunaria_refresh_secret_key_random_string_123456789
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Mail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=example@gmail.com
MAIL_PASS=your_app_password_here
MAIL_FROM="Lunaria Shop" <example@gmail.com>

# Frontend URL
FRONTEND_URL=http://localhost:8000
